---
// Obsidian-style quick switcher: fuzzy-jump to any note. ⌘K / Ctrl-K.
---

<div id="switcher" class="fixed inset-0 z-[70] hidden" role="dialog" aria-modal="true" aria-label="Jump to note">
  <div id="switcher-scrim" class="absolute inset-0 bg-[var(--ink)]/25 backdrop-blur-[2px]"></div>
  <div class="relative mx-auto mt-[12vh] w-[min(34rem,92vw)]">
    <div class="hairline overflow-hidden rounded-sm bg-paper-raised shadow-xl">
      <input
        id="switcher-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        placeholder="Jump to a note…"
        class="w-full bg-transparent px-4 py-3 font-mono text-sm text-ink outline-none placeholder:text-ink-faint"
      />
      <ul id="switcher-results" class="max-h-[46vh] overflow-y-auto border-t border-[var(--hairline)]"></ul>
    </div>
    <p class="mt-2 text-center font-mono text-[0.7rem] text-ink-faint">↑↓ to move · ↵ to open · esc to close</p>
  </div>
</div>

<script>
  import { navigate } from "astro:transitions/client";

  type Item = { id: string; title: string; url: string; group: string };

  const GROUP_LABEL: Record<string, string> = {
    hub: "Pages",
    interest: "Interests",
    hobby: "Life",
    book: "Bookshelf",
    category: "Topics",
    blog: "Writing",
    meta: "Meta",
  };
  // the order sections appear when you haven't typed anything
  const GROUP_ORDER: Record<string, number> = {
    hub: 0,
    interest: 1,
    hobby: 2,
    book: 3,
    category: 4,
    blog: 5,
    meta: 6,
  };
  const rank = (g: string) => GROUP_ORDER[g] ?? 99;

  let items: Item[] = [];
  let filtered: Item[] = [];
  let query = "";
  let active = 0;

  async function loadIndex() {
    if (items.length) return;
    try {
      const data = await fetch("/graph.json").then((r) => r.json());
      items = data.nodes.map((n: any) => ({ id: n.id, title: n.title, url: n.url, group: n.group }));
      // default (empty query) order: by section, then alphabetically
      items.sort((a, b) => rank(a.group) - rank(b.group) || a.title.localeCompare(b.title));
    } catch {
      items = [];
    }
  }

  /**
   * Relevance score — lower is better, -1 means no match.
   * Tiers: exact prefix < word-start < substring < subsequence.
   */
  function score(q: string, title: string): number {
    if (!q) return 0;
    const s = title.toLowerCase();
    q = q.toLowerCase();

    if (s.startsWith(q)) return 0; // "mach" -> "Machine Learning"
    // start of any word: "mach" -> "Why *Mach*ines Learn"
    for (const m of s.matchAll(/\b\w/g)) {
      if (s.startsWith(q, m.index!)) return 1 + m.index! / 1000;
    }
    const idx = s.indexOf(q);
    if (idx >= 0) return 10 + idx / 1000; // substring anywhere

    // subsequence fallback: "wml" -> "Why Machines Learn"
    let qi = 0,
      gaps = 0,
      last = -1;
    for (let i = 0; i < s.length && qi < q.length; i++) {
      if (s[i] === q[qi]) {
        if (last >= 0) gaps += i - last - 1;
        last = i;
        qi++;
      }
    }
    return qi === q.length ? 100 + gaps : -1;
  }

  function render() {
    const list = document.getElementById("switcher-results")!;
    list.innerHTML = "";
    const searching = query.length > 0;
    let lastGroup = "";

    filtered.forEach((it, i) => {
      // section headers only when browsing (no query); when searching we sort by
      // relevance instead, and tag each row with its section so it stays legible
      if (!searching && it.group !== lastGroup) {
        lastGroup = it.group;
        const h = document.createElement("li");
        h.className =
          "px-4 pt-2 pb-1 font-mono text-[0.65rem] uppercase tracking-wider text-ink-faint";
        h.textContent = GROUP_LABEL[it.group] ?? it.group;
        list.appendChild(h);
      }

      const li = document.createElement("li");
      li.dataset.idx = String(i);
      li.className =
        "flex cursor-pointer items-baseline justify-between gap-4 px-4 py-2 text-sm " +
        (i === active ? "bg-accent/10 text-accent" : "text-ink hover:bg-[var(--hairline)]/40");

      const name = document.createElement("span");
      name.textContent = it.title;
      li.appendChild(name);

      if (searching) {
        const tag = document.createElement("span");
        tag.className = "shrink-0 font-mono text-[0.65rem] uppercase tracking-wider text-ink-faint";
        tag.textContent = GROUP_LABEL[it.group] ?? it.group;
        li.appendChild(tag);
      }

      li.addEventListener("mouseenter", () => {
        if (active === i) return;
        active = i;
        render();
      });
      li.addEventListener("click", () => go(it));
      list.appendChild(li);
    });

    if (filtered.length === 0) {
      const empty = document.createElement("li");
      empty.className = "px-4 py-3 font-mono text-xs text-ink-faint";
      empty.textContent = "no matches";
      list.appendChild(empty);
    }
  }

  function filter(q: string) {
    query = q.trim();
    if (!query) {
      filtered = [...items]; // already sorted by section, then title
    } else {
      filtered = items
        .map((it) => ({ it, s: score(query, it.title) }))
        .filter((x) => x.s >= 0)
        // best match first; ties broken by section, then alphabetically
        .sort(
          (a, b) =>
            a.s - b.s ||
            rank(a.it.group) - rank(b.it.group) ||
            a.it.title.localeCompare(b.it.title),
        )
        .map((x) => x.it);
    }
    active = 0;
    render();
  }

  function scrollActiveIntoView() {
    const list = document.getElementById("switcher-results");
    const el = list?.querySelector<HTMLElement>(`li[data-idx="${active}"]`);
    el?.scrollIntoView({ block: "nearest" });
  }

  function open() {
    const el = document.getElementById("switcher")!;
    const input = document.getElementById("switcher-input") as HTMLInputElement;
    loadIndex().then(() => {
      input.value = "";
      filter("");
      el.classList.remove("hidden");
      input.focus();
    });
  }
  function close() {
    document.getElementById("switcher")?.classList.add("hidden");
  }
  function go(it: Item) {
    close();
    navigate(it.url);
  }

  if (!(window as any).__switcherBound) {
    (window as any).__switcherBound = true;

    document.addEventListener("switcher:open", open);

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        open();
        return;
      }
      const el = document.getElementById("switcher");
      if (!el || el.classList.contains("hidden")) return;
      if (e.key === "Escape") {
        e.preventDefault();
        close();
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        active = Math.min(active + 1, filtered.length - 1);
        render();
        scrollActiveIntoView();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        active = Math.max(active - 1, 0);
        render();
        scrollActiveIntoView();
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (filtered[active]) go(filtered[active]);
      }
    });

    document.addEventListener("input", (e) => {
      if ((e.target as HTMLElement).id === "switcher-input")
        filter((e.target as HTMLInputElement).value);
    });

    document.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).id === "switcher-scrim") close();
    });
  }
</script>
